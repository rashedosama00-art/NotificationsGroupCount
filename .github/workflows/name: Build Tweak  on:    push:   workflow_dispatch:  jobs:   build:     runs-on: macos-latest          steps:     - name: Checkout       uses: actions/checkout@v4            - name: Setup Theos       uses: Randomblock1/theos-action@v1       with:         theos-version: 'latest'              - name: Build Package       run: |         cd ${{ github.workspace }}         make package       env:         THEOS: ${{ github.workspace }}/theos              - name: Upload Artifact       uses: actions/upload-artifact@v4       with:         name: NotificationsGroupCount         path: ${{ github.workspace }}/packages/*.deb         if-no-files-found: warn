name: Build Tweak

on: [push, workflow_dispatch]

jobs:
  build:
    runs-on: macos-latest
    
    steps:
    - uses: actions/checkout@v3
    
    - name: Setup Theos
      uses: Randomblock1/theos-action@v1
    
    - name: Build Package
      run: make package
      
    - name: Upload Artifact
      uses: actions/upload-artifact@v3
      with:
        name: NotificationsGroupCount
        path: packages/*.deb
